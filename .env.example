# ─── Core ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/swipehire
REDIS_URL=redis://localhost:6379
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
NODE_ENV=development
API_PORT=3000
# Production CORS allowlist (comma-separated). Leave blank in dev (allows all).
ALLOWED_ORIGINS=

# ─── Recruiter outreach (optional) ───────────────────────────────────────────
# Email provider for the "Reach out" feature. Without these, outreach messages
# are saved as drafts instead of being sent.
RESEND_API_KEY=
OUTREACH_FROM_EMAIL=outreach@swipehire.app

# ─── Recruiter contacts (optional) ───────────────────────────────────────────
# Hunter.io auto-finds a real recruiter contact for outreach (primary source;
# careers@<domain> is the fallback). Looked up lazily — at most one Hunter call
# per company per month — and the company needs a website/domain set.
HUNTER_API_KEY=

# ─── Glassdoor reviews (optional) ────────────────────────────────────────────
# Glassdoor's Employer Reviews API is partner-only (no self-serve key). Leave
# these blank to show in-app reviews only; set them once you have partner access.
GLASSDOOR_PARTNER_ID=
GLASSDOOR_API_KEY=
# GLASSDOOR_API_URL=https://api.glassdoor.com/api/api.htm

# ─── Glassdoor reviews via RapidAPI (optional, worker only) ──────────────────
# "Real-Time Glassdoor Data" (OpenWeb Ninja) on RapidAPI. The background worker
# (`pnpm sync:reviews`) pulls employer reviews into the reviews table. It's a
# third-party feed scraping Glassdoor — you accept the source's ToS/legal terms.
RAPIDAPI_KEY=
# RAPIDAPI_GLASSDOOR_HOST=real-time-glassdoor-data.p.rapidapi.com
# GLASSDOOR_REVIEWS_MAX=20
# REVIEWS_REFRESH_DAYS=7   # skip companies refreshed within this many days (0 = always)

# ─── JSearch aggregated jobs (optional, worker only) ─────────────────────────
# Pulls LinkedIn/Indeed/ZipRecruiter/Glassdoor postings via JSearch on RapidAPI
# (same RAPIDAPI_KEY — subscribe to JSearch separately). Run: pnpm sync:jsearch
# JSEARCH_QUERIES=software engineer in united states, product designer remote
# JSEARCH_HOST=jsearch.p.rapidapi.com
