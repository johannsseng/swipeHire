# Copy this file to .env.local  (cp .env.local.example .env.local)
#
# Where the app's API lives:
#   • Easiest (no backend setup needed) — use the deployed production API:
EXPO_PUBLIC_API_URL=https://swipehire-api-vhsg.onrender.com
#
#   • Or, if you're running the API locally (pnpm dev:api), use:
# EXPO_PUBLIC_API_URL=http://localhost:3000
