// SwipeHire Prisma schema
// Source of truth: docs/schema.md

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


// ─── Enums ──────────────────────────────────────────────────────────────────

enum VerifiedTier {
  unverified
  partial
  verified
}

enum UserRole {
  user
  admin
}

enum JobSource {
  greenhouse
  lever
  manual
}

enum ApplyMethod {
  deeplink
  greenhouse_post
  lever_post
}

enum SwipeDirection {
  left
  right
}

enum ApplicationStatus {
  queued
  submitted
  deeplinked
  failed
}

enum EmploymentType {
  full_time
  contract
  intern
}

enum VerificationSignalType {
  linkedin_oauth
  github_oauth
  phone
  edu_email
  resume_coherence
}

enum ReviewSource {
  in_app
  glassdoor
}

enum OutreachStatus {
  draft
  queued
  sent
  failed
}

// Pipeline stage for a saved job (lives on the right-swipe record).
enum TrackStatus {
  saved
  applied
  screening
  interview
  accepted
  rejected
}

// ─── Models ─────────────────────────────────────────────────────────────────

model User {
  id            String       @id @default(uuid()) @db.Uuid
  email         String       @unique
  passwordHash  String       @map("password_hash")
  emailVerified Boolean      @default(false) @map("email_verified")
  verifiedTier  VerifiedTier @default(unverified) @map("verified_tier")
  role          UserRole     @default(user)
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  profile       Profile?
  swipes        Swipe[]
  applications  Application[]
  verifications Verification[]
  reviews       Review[]
  outreaches    Outreach[]

  @@map("users")
}

model Profile {
  userId       String   @id @map("user_id") @db.Uuid
  fullName     String?  @map("full_name")
  headline     String?
  bio          String?  @db.Text
  location     String?
  links        Json?    @db.JsonB
  resumeUrl    String?  @map("resume_url")
  resumeParsed Json?    @map("resume_parsed") @db.JsonB
  preferences  Json?    @db.JsonB
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Company {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  source       JobSource
  boardToken   String    @map("board_token")
  website      String?
  logoUrl      String?   @map("logo_url")
  active       Boolean   @default(true)
  lastSyncedAt DateTime? @map("last_synced_at") @db.Timestamptz
  syncError    String?   @map("sync_error") @db.Text

  // Recruiter contact (used by the outreach feature)
  recruiterName  String? @map("recruiter_name")
  recruiterEmail String? @map("recruiter_email")
  recruiterTitle String? @map("recruiter_title")
  // When we last attempted Hunter auto-enrichment (avoids re-querying misses).
  recruiterEnrichedAt DateTime? @map("recruiter_enriched_at") @db.Timestamptz

  // External reviews reference (e.g. Glassdoor employer id)
  glassdoorId  String?   @map("glassdoor_id")

  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  jobs         Job[]
  reviews      Review[]

  @@unique([source, boardToken])
  @@index([active, lastSyncedAt])
  @@map("companies")
}

model Job {
  id              String          @id @default(uuid()) @db.Uuid
  companyId       String          @map("company_id") @db.Uuid
  source          JobSource
  sourceId        String          @map("source_id")
  title           String
  location        String?
  remote          Boolean         @default(false)
  employmentType  EmploymentType? @map("employment_type")
  descriptionHtml String?         @map("description_html") @db.Text
  descriptionText String?         @map("description_text") @db.Text
  applyUrl        String          @map("apply_url")
  applyMethod     ApplyMethod     @map("apply_method")
  postedAt        DateTime?       @map("posted_at") @db.Timestamptz
  active          Boolean         @default(true)
  raw             Json            @db.JsonB
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  company         Company         @relation(fields: [companyId], references: [id])
  swipes          Swipe[]
  applications    Application[]
  outreaches      Outreach[]

  @@unique([source, sourceId])
  @@index([active, postedAt(sort: Desc)])
  @@index([companyId])
  @@map("jobs")
}

model Swipe {
  id        String         @id @default(uuid()) @db.Uuid
  userId    String         @map("user_id") @db.Uuid
  jobId     String         @map("job_id") @db.Uuid
  direction SwipeDirection

  // Application pipeline tracking for saved (right-swiped) jobs.
  trackStatus    TrackStatus @default(saved) @map("track_status")
  trackUpdatedAt DateTime?   @map("track_updated_at") @db.Timestamptz

  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  job       Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId, direction, createdAt(sort: Desc)])
  @@map("swipes")
}

model Application {
  id          String            @id @default(uuid()) @db.Uuid
  userId      String            @map("user_id") @db.Uuid
  jobId       String            @map("job_id") @db.Uuid
  status      ApplicationStatus
  applyMethod ApplyMethod?      @map("apply_method")
  resumeUrl   String?           @map("resume_url")
  coverLetter String?           @map("cover_letter") @db.Text
  answers     Json?             @db.JsonB
  submittedAt DateTime?         @map("submitted_at") @db.Timestamptz
  response    Json?             @db.JsonB
  error       String?           @db.Text
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  job         Job               @relation(fields: [jobId], references: [id])

  @@unique([userId, jobId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt])
  @@map("applications")
}

model Verification {
  id          String                 @id @default(uuid()) @db.Uuid
  userId      String                 @map("user_id") @db.Uuid
  signalType  VerificationSignalType @map("signal_type")
  signalValue Json                   @map("signal_value") @db.JsonB
  verifiedAt  DateTime               @default(now()) @map("verified_at") @db.Timestamptz
  createdAt   DateTime               @default(now()) @map("created_at") @db.Timestamptz

  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, signalType])
  @@map("verifications")
}

model Review {
  id          String       @id @default(uuid()) @db.Uuid
  companyId   String       @map("company_id") @db.Uuid
  userId      String?      @map("user_id") @db.Uuid // null for externally-sourced reviews
  source      ReviewSource @default(in_app)
  rating      Int          // 1–5
  title       String?
  body        String?      @db.Text
  pros        String?      @db.Text
  cons        String?      @db.Text
  authorTitle String?      @map("author_title") // e.g. "Software Engineer"
  externalId  String?      @map("external_id") // provider-side id, for de-duping
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([userId, companyId]) // one in-app review per user per company
  @@unique([source, externalId])
  @@index([companyId, createdAt(sort: Desc)])
  @@map("reviews")
}

model Outreach {
  id             String         @id @default(uuid()) @db.Uuid
  userId         String         @map("user_id") @db.Uuid
  jobId          String         @map("job_id") @db.Uuid
  recruiterEmail String         @map("recruiter_email")
  subject        String
  body           String         @db.Text
  status         OutreachStatus @default(draft)
  providerId     String?        @map("provider_id") // id returned by the email provider
  sentAt         DateTime?      @map("sent_at") @db.Timestamptz
  error          String?        @db.Text
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  job            Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([jobId])
  @@map("outreaches")
}