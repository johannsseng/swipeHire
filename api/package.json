{
  "name": "@swipehire/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../.env src/index.ts",
    "build": "tsc",
    "start": "node --env-file=../.env dist/index.js",
    "start:prod": "tsx src/index.ts",
    "prisma:generate": "prisma generate",
    "migrate:deploy": "prisma migrate deploy",
    "db:push:prod": "prisma db push --skip-generate",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
"test": "find src -name \"*.test.ts\" | grep -q . && node --import tsx --test src/**/*.test.ts || echo \"No API tests found\""    "db:push": "dotenv -e ../.env -- prisma db push",
    "db:migrate": "dotenv -e ../.env -- prisma migrate dev",
    "db:reset": "dotenv -e ../.env -- prisma migrate reset",
    "db:studio": "dotenv -e ../.env -- prisma studio",
    "db:seed": "dotenv -e ../.env -- tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.8.0",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.19.3",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "zod": "^4.4.3"
  }
}
